# Copy this file to .env.development, .env.test, .env.staging, or .env.production
# Never commit .env.* files (other than this example) to source control.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development            # development | test | staging | production
DEBUG=true
LOG_LEVEL=DEBUG                # DEBUG | INFO | WARNING | ERROR

# ── Scan Engine ────────────────────────────────────────────────────────────────
SCAN_RATE_MS=100               # Scan cycle interval in milliseconds
SESSION_IDLE_TIMEOUT_MIN=30    # Minutes before an idle session is torn down

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./plc_emulator.db
# For PostgreSQL (post-MVP): postgresql://user:password@localhost/plc_emulator

# ── Authentication ─────────────────────────────────────────────────────────────
SECRET_KEY=replace-this-with-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
